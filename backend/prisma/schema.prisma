generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

// ==========================================
// NHÓM NGƯỜI DÙNG
// ==========================================

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @db.VarChar(255)
  email        String   @unique @db.VarChar(100)
  role         String   @db.VarChar(20)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  customer    Customer?
  technician  Technician?
  partImports PartImport[]
}

model Customer {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  fullName       String   @db.NVarChar(100)
  phone          String   @db.VarChar(20)
  additionalInfo String?  @db.NVarChar(255)
  createdAt      DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  devices Device[]
}

model Technician {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  fullName  String   @db.NVarChar(100)
  phone     String   @db.VarChar(20)
  createdAt DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  technicianSkills TechnicianSkill[]
  workOrders       WorkOrder[]
}

model TechnicianSkill {
  id               Int @id @default(autoincrement())
  technicianId     Int
  deviceCategoryId Int

  technician     Technician     @relation(fields: [technicianId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deviceCategory DeviceCategory @relation(fields: [deviceCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ==========================================
// NHÓM THIẾT BỊ
// ==========================================

model DeviceCategory {
  id          Int     @id @default(autoincrement())
  name        String  @db.NVarChar(100)
  description String? @db.NVarChar(255)

  technicianSkills TechnicianSkill[]
  devices          Device[]
}

model Device {
  id           Int       @id @default(autoincrement())
  categoryId   Int
  customerId   Int
  name         String    @db.NVarChar(100)
  brand        String    @db.NVarChar(100)
  model        String    @db.NVarChar(100)
  serialNumber String    @unique @db.VarChar(100)
  address      String    @db.NVarChar(255)
  purchaseDate DateTime?
  status       String    @default("active") @db.VarChar(20)
  createdAt    DateTime  @default(now())

  category             DeviceCategory        @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer             Customer              @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warrantyContracts    WarrantyContract[]
  tickets              Ticket[]
  maintenanceSchedules MaintenanceSchedule[]
}

// ==========================================
// NHÓM BẢO HÀNH
// ==========================================

model WarrantyContract {
  id             Int      @id @default(autoincrement())
  deviceId       Int
  contractNumber String   @unique @db.VarChar(50)
  startDate      DateTime
  endDate        DateTime
  terms          String?  @db.NVarChar(Max)
  status         String   @default("active") @db.VarChar(20)
  createdAt      DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ==========================================
// NHÓM TICKET & BẢO TRÌ (WORK ORDER)
// ==========================================

model Ticket {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  title       String   @db.NVarChar(200)
  description String   @db.NVarChar(Max)
  priority    String   @default("medium") @db.VarChar(20)
  status      String   @default("pending") @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  device     Device      @relation(fields: [deviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workOrders WorkOrder[]
}

model MaintenanceSchedule {
  id                  Int       @id @default(autoincrement())
  deviceId            Int
  lastMaintenanceDate DateTime @default(now())
  nextMaintenanceDate DateTime?
  leadTimeDays        Int      @default(7)
  isHandled            Boolean  @default(false)
  isContinueMaintain  Boolean  @default(true)

  device     Device      @relation(fields: [deviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workOrders WorkOrder[]
}

model WorkOrder {
  id                    Int       @id @default(autoincrement())
  ticketId              Int?
  maintenanceScheduleId Int?
  technicianId          Int
  workDescription       String?   @db.NVarChar(1000)
  status                String    @default("pending") @db.VarChar(20)
  createdAt             DateTime  @default(now())
  startedAt             DateTime?
  completedAt           DateTime?

  ticket              Ticket?              @relation(fields: [ticketId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  maintenanceSchedule MaintenanceSchedule? @relation(fields: [maintenanceScheduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  technician          Technician           @relation(fields: [technicianId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partUsages          PartUsage[]
}

// ==========================================
// NHÓM KHO LINH KIỆN (PARTS)
// ==========================================

model Part {
  id            Int     @id @default(autoincrement())
  name          String  @db.NVarChar(100)
  code          String  @unique @db.VarChar(50)
  unit          String  @db.NVarChar(50)
  stockQuantity Int     @default(0)
  minQuantity   Int     @default(0)
  description   String? @db.NVarChar(255)

  partUsages        PartUsage[]
  partImportDetails PartImportDetail[]
}

model PartUsage {
  id            Int @id @default(autoincrement())
  workOrderId   Int
  partId        Int
  quantityUsage Int

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  part      Part      @relation(fields: [partId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PartImport {
  id         Int      @id @default(autoincrement())
  importedBy Int
  supplier   String   @db.NVarChar(100)
  importDate DateTime
  totalCost  Decimal  @db.Decimal(18, 2)
  note       String?  @db.NVarChar(255)

  user    User               @relation(fields: [importedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  details PartImportDetail[]
}

model PartImportDetail {
  id        Int     @id @default(autoincrement())
  importId  Int
  partId    Int
  quantity  Int
  unitPrice Decimal @db.Decimal(18, 2)

  import PartImport @relation(fields: [importId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  part   Part       @relation(fields: [partId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
